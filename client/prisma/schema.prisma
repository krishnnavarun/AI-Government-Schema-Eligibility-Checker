generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(uuid())

  name        String
  email       String   @unique

  age         Int?
  gender      String?

  state       String?
  district    String?

  occupation  String?

  income      Float?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications Application[]
}

model Scheme {
  id          String   @id @default(uuid())

  name        String
  description String
  benefits    String

  ministry    String?

  eligibility Json

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications Application[]
}

model Application {
  id        String   @id @default(uuid())

  userId    String
  schemeId  String

  status    String @default("PENDING")

  user      User   @relation(fields: [userId], references: [id])
  scheme    Scheme @relation(fields: [schemeId], references: [id])

  createdAt DateTime @default(now())
}